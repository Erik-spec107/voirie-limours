<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/teal"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:text="Voirie Limours"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvCount"
                android:text="0 désordre"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:alpha="0.8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnExport"
            android:text="Envoyer ✉"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:background="@drawable/btn_outline_white"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </LinearLayout>

    <!-- TABS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/card">

        <TextView
            android:id="@+id/tabSaisie"
            android:text="＋ Saisie"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textColor="@color/teal"
            android:background="@drawable/tab_selected"/>

        <TextView
            android:id="@+id/tabListe"
            android:text="Liste"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textColor="@color/muted"
            android:background="@drawable/tab_normal"/>
    </LinearLayout>

    <!-- CONTENU -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- PAGE SAISIE -->
        <ScrollView
            android:id="@+id/pageSaisie"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- GPS -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/card_bg"
                    android:padding="14dp" android:layout_marginBottom="10dp">
                    <TextView android:text="POSITION GPS" android:textSize="12sp"
                        android:textColor="@color/muted" android:textStyle="bold"
                        android:letterSpacing="0.05" android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <Button android:id="@+id/btnGps"
                        android:text="📍  Localiser automatiquement"
                        android:textColor="@color/white" android:textSize="15sp"
                        android:background="@drawable/btn_teal"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tvGpsResult"
                        android:text="Position non enregistrée"
                        android:textSize="13sp" android:textColor="@color/muted"
                        android:background="@drawable/input_bg"
                        android:padding="10dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:weightSum="1">
                        <EditText android:id="@+id/etRue"
                            android:hint="Rue (facultatif)"
                            android:background="@drawable/input_bg"
                            android:padding="11dp" android:textSize="15sp"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="0.72" android:layout_marginEnd="8dp"
                            android:inputType="text"/>
                        <EditText android:id="@+id/etNum"
                            android:hint="N°"
                            android:background="@drawable/input_bg"
                            android:padding="11dp" android:textSize="15sp"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="0.28"
                            android:inputType="text"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- TYPES -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/card_bg"
                    android:padding="14dp" android:layout_marginBottom="10dp">
                    <TextView android:text="TYPE DE DÉSORDRE — sélection multiple"
                        android:textSize="12sp" android:textColor="@color/muted"
                        android:textStyle="bold" android:letterSpacing="0.05"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <GridLayout android:id="@+id/gridTypes"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:columnCount="2" android:rowCount="4"
                        android:useDefaultMargins="false"/>
                    <EditText android:id="@+id/etAutre"
                        android:hint="Préciser…"
                        android:background="@drawable/input_bg"
                        android:padding="11dp" android:textSize="15sp"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        android:inputType="text"/>
                </LinearLayout>

                <!-- GRAVITÉ -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/card_bg"
                    android:padding="14dp" android:layout_marginBottom="10dp">
                    <TextView android:text="GRAVITÉ"
                        android:textSize="12sp" android:textColor="@color/muted"
                        android:textStyle="bold" android:letterSpacing="0.05"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <LinearLayout android:id="@+id/layoutGravite"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal"/>
                </LinearLayout>

                <!-- PHOTO -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/card_bg"
                    android:padding="14dp" android:layout_marginBottom="10dp">
                    <TextView android:text="PHOTO"
                        android:textSize="12sp" android:textColor="@color/muted"
                        android:textStyle="bold" android:letterSpacing="0.05"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <LinearLayout android:id="@+id/photoZone"
                        android:layout_width="match_parent" android:layout_height="80dp"
                        android:background="@drawable/photo_placeholder"
                        android:gravity="center" android:orientation="horizontal">
                        <TextView android:text="📷  Prendre / choisir une photo"
                            android:textSize="14sp" android:textColor="@color/muted"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/imgPreview"
                        android:layout_width="match_parent" android:layout_height="180dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/card_bg"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"/>
                    <Button android:id="@+id/btnDelPhoto"
                        android:text="✕  Supprimer la photo"
                        android:textColor="@color/red"
                        android:textSize="13sp"
                        android:background="@drawable/btn_red_outline"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- COMMENTAIRE -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/card_bg"
                    android:padding="14dp" android:layout_marginBottom="10dp">
                    <TextView android:text="COMMENTAIRE (facultatif)"
                        android:textSize="12sp" android:textColor="@color/muted"
                        android:textStyle="bold" android:letterSpacing="0.05"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/etComment"
                        android:hint="Observations…"
                        android:background="@drawable/input_bg"
                        android:padding="11dp" android:textSize="15sp"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:minLines="3" android:gravity="top"
                        android:inputType="textMultiLine"/>
                </LinearLayout>

                <!-- BOUTON ENREGISTRER -->
                <Button android:id="@+id/btnSave"
                    android:text="Enregistrer le désordre"
                    android:textColor="@color/white" android:textSize="17sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_teal_disabled"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:enabled="false"
                    android:layout_marginBottom="8dp"/>

                <TextView android:id="@+id/tvHint"
                    android:text="Sélectionnez au moins un type et une gravité"
                    android:textSize="12sp" android:textColor="@color/muted"
                    android:gravity="center"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"/>

            </LinearLayout>
        </ScrollView>

        <!-- PAGE LISTE -->
        <LinearLayout
            android:id="@+id/pageListe"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <!-- STATS -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <LinearLayout android:id="@+id/statTotal"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/card_bg" android:padding="10dp"
                    android:gravity="center" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvTotal" android:text="0"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Total" android:textSize="11sp" android:textColor="@color/muted"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/card_bg" android:padding="10dp"
                    android:gravity="center" android:layout_marginStart="4dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tvGraves" android:text="0"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Graves 4-5" android:textSize="11sp" android:textColor="@color/muted"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/card_bg" android:padding="10dp"
                    android:gravity="center" android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tvAujourd" android:text="0"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Aujourd'hui" android:textSize="11sp" android:textColor="@color/muted"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
                <LinearLayout android:id="@+id/listeContent"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>

        </LinearLayout>
    </FrameLayout>

</LinearLayout>
